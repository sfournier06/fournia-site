<script is:inline>
  // nav scroll state
  const nav = document.getElementById('nav');
  addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 30));

  // reveal on scroll
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: .15 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // trigger hero reveals immediately
  addEventListener('load', () => document.querySelectorAll('header .reveal').forEach(el => el.classList.add('in')));

  // subtle parallax on hero nodes
  addEventListener('mousemove', (e) => {
    const x = (e.clientX / innerWidth - .5), y = (e.clientY / innerHeight - .5);
    document.querySelectorAll('.node').forEach((n, i) => {
      const d = (i + 1) * 8;
      n.style.transform = `translate(${x * d}px, ${y * d}px)`;
    });
  });

  // mobile burger -> toggle dropdown menu (mêmes sections que desktop)
  const burger = document.getElementById('burger');
  burger.addEventListener('click', (e) => { e.stopPropagation(); nav.classList.toggle('open'); });
  document.querySelectorAll('.nav-links a').forEach(a => a.addEventListener('click', () => nav.classList.remove('open')));
  document.addEventListener('click', (e) => { if (!nav.contains(e.target)) nav.classList.remove('open'); });
</script>

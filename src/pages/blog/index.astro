---
import { getCollection } from 'astro:content';

// Bibliothèque publique profonde : liste TOUS les posts, du plus récent au plus ancien.
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://fournia.net';
---
<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog | FournIA</title>
    <meta name="description" content="Articles de FournIA sur l'IA et l'automatisation pour les PME québécoises : coûts, ROI, outils, Loi 25." />
    <link rel="canonical" href={`${siteUrl}/blog`} />
  </head>
  <body>
    <header><a href="/">FournIA</a> &rsaquo; Blog</header>
    <main>
      <h1>Blog FournIA</h1>
      <p>L'IA et l'automatisation pour les PME du Québec, expliquées simplement.</p>
      <ul>
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            <p>{post.data.description}</p>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>

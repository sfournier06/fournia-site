---
// Layout d'article de blog. Émet le JSON-LD statique au build :
// Article + FAQPage + Organization + BreadcrumbList.
const { id, title, description, pubDate, updatedDate, author, publisher, heroImage, heroAlt, tags, faq } = Astro.props;

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://fournia.net';
const canonical = `${siteUrl}/blog/${id}`;
const published = (pubDate instanceof Date ? pubDate : new Date(pubDate)).toISOString();
const modified = (updatedDate ? (updatedDate instanceof Date ? updatedDate : new Date(updatedDate)) : (pubDate instanceof Date ? pubDate : new Date(pubDate))).toISOString();

const organization = {
  '@type': 'Organization',
  name: 'FournIA',
  url: siteUrl,
  founder: { '@type': 'Person', name: 'Simon Fournier' },
  areaServed: 'Québec, Rive-Nord de Montréal',
  description: "Consultation en IA pour PME québécoises : automatisations N8N, agents Claude API, formation. Conforme à la Loi 25.",
};

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  inLanguage: 'fr-CA',
  datePublished: published,
  dateModified: modified,
  author: { '@type': 'Person', name: author ?? 'Simon Fournier' },
  publisher: organization,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  ...(heroImage ? { image: new URL(heroImage.replace('./', `/blog/`), siteUrl).href } : {}),
  keywords: (tags ?? []).join(', '),
};

const faqLd = (faq && faq.length > 0)
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    }
  : null;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};
---
<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | FournIA</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_CA" />
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
    {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </head>
  <body>
    <header><a href="/">FournIA</a> &rsaquo; <a href="/blog">Blog</a></header>
    <main>
      <article>
        <h1>{title}</h1>
        <p><time datetime={published}>Publié le {published.slice(0, 10)}</time> par {author ?? 'Simon Fournier'}</p>
        {heroImage && <img src={heroImage.replace('./', '/blog/')} alt={heroAlt ?? title} />}
        <slot />
      </article>
    </main>
    <footer>
      <p>FournIA, consultation en IA pour PME québécoises (Rive-Nord de Montréal). Conforme Loi 25.</p>
    </footer>
  </body>
</html>

---
// Shell partagé du site (nav + fond + footer + design system).
// Utilisé par les pages qui doivent matcher l'accueil (blog, articles).
import '../styles/global.css';

const { title, description, canonical, ogType = 'website' } = Astro.props;
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://fournia.net';
const cta = 'https://calendly.com/s-fournier-fournia/discovery-call-fournia';
---
<!doctype html>
<html lang="fr-CA">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:locale" content="fr_CA" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Syne:wght@700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <slot name="head" />
</head>
<body>
  <div class="bg-fx">
    <div class="grid-lines"></div>
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>

  <nav id="nav">
    <div class="nav-inner">
      <a href="/" class="logo"><span class="dot"></span><span>Fourn<span class="ia">IA</span></span></a>
      <ul class="nav-links">
        <li><a href="/#apropos">À propos</a></li>
        <li><a href="/#services">Services</a></li>
        <li><a href="/#processus">Processus</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
      <a href={cta} target="_blank" rel="noopener" class="btn btn-primary">Réserver un appel <span class="arrow">→</span></a>
      <div class="hamburger" id="burger"><span></span><span></span><span></span></div>
    </div>
  </nav>

  <slot />

  <footer>
    <div class="wrap">
      <div class="foot-grid">
        <div>
          <a href="/" class="logo" style="font-size:1.5rem"><span class="dot"></span><span>Fourn<span class="ia">IA</span></span></a>
          <p style="color:var(--mute-d); margin-top:1rem; max-width:280px; font-size:.92rem;">L'IA concrète, clé en main, pour les PME québécoises.</p>
        </div>
        <div class="foot-contact">
          <a href="mailto:s.fournier@fournia.net">s.fournier@fournia.net</a>
          <a href="tel:+15148632973">514 863 2973</a>
          <a href="/">fournia.net</a>
        </div>
        <div class="foot-contact">
          <a href="/#apropos">À propos</a>
          <a href="/#services">Services</a>
          <a href="/#processus">Processus</a>
          <a href="/blog">Blog</a>
          <a href={cta} target="_blank" rel="noopener">Réserver un appel</a>
        </div>
      </div>
      <div class="foot-bottom">© 2026 FournIA. Tous droits réservés.</div>
    </div>
  </footer>

  <script is:inline>
    const nav = document.getElementById('nav');
    addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 30));
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: .15 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    addEventListener('load', () => document.querySelectorAll('main .reveal').forEach(el => el.classList.add('in')));
    const burger = document.getElementById('burger');
    if (burger) burger.addEventListener('click', (e) => { e.stopPropagation(); nav.classList.toggle('open'); });
    document.querySelectorAll('.nav-links a').forEach(a => a.addEventListener('click', () => nav.classList.remove('open')));
    document.addEventListener('click', (e) => { if (!nav.contains(e.target)) nav.classList.remove('open'); });
  </script>
</body>
</html>
